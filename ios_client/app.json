{
  "expo": {
    "name": "Quizza",
    "slug": "quizza",
    "version": "1.3.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.quizza.app",
      "usesAppleSignIn": true,
      "buildNumber": "47",
      "associatedDomains": [
        "applinks:quizza-eta.vercel.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-secure-store",
      "@sentry/react-native",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-web-browser"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.quizza.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json"
    },
    "scheme": "quizza",
    "extra": {
      "eas": {
        "projectId": "0f7738f4-08c1-49bf-b9c7-70b6560f8c05"
      }
    }
  }
}
